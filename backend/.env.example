# ========================================
# AgroMart Backend - Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values

# PostgreSQL Database
DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/database_name

# MongoDB Database
MONGODB_URL=mongodb://localhost:27017/

# JWT Authentication
SECRET_KEY=your-very-secret-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Agmarknet API (Get your key from https://data.gov.in/)
AGMARKNET_API_KEY=your-agmarknet-api-key-here

# Kafka Configuration (Optional - for order processing)
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_ORDER_TOPIC=order-topic
